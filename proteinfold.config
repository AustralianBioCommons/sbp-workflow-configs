// SBP Gadi configuration for nf-core/proteinfold

// NCI Gadi nf-core configuration profile
plugins {
    id 'nf-gadi@1.2.0'
}

// SBP required parameters; these are populated at runtime by the BioCommons service layer
params {
    alphafold2_db                   = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/'
    alphafold2_bfd_path             = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/bfd/*'
    alphafold2_small_bfd_path       = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/small_bfd/*'
    alphafold2_params_path          = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/alphafold_params_2022-12-06/*'
    alphafold2_mgnify_path          = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/mgnify/*'
    alphafold2_pdb70_path           = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/pdb70/**'
    alphafold2_pdb_mmcif_path       = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/pdb_mmcif/mmcif_files'
    alphafold2_pdb_obsolete_path    = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/pdb_mmcif/obsolete.dat'
    alphafold2_uniref30_path        = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/uniref30/*'
    alphafold2_uniref90_path        = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/uniref90/*'
    alphafold2_pdb_seqres_path      = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/pdb_seqres/*'
    alphafold2_uniprot_path         = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/uniprot/*'

    colabfold_db                        = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/'
    colabfold_envdb_path                = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/colabfold_envdb/*'
    colabfold_uniref30_path             = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/colabfold_uniref30/*'
    colabfold_alphafold2_params_path    = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/alphafold_params_2022-12-06'

    boltz_db            = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/'
    boltz_ccd_path      = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/ccd.pkl'
    boltz_model_path    = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/boltz1_conf.ckpt'
    boltz2_aff_path     = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/boltz2_aff.ckpt'
    boltz2_conf_path    = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/boltz2_conf.ckpt'
    boltz2_mols_path    = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/params/mols/'
}

process {
    executor     = 'pbspro'
    // clusterOptions would be filled from backend
    storage      = 'gdata/ll61+gdata/if89+gdata/li87'
    module       = 'singularity'
    cache        = 'lenient'
    stageInMode  = 'symlink'
    beforeScript = 'module load singularity'
    scratch       = true
    disk          = 20.GB

    // NOTE: base.config uses (175..177); this config only retries on 175
    errorStrategy = { task.exitStatus in ((130..145) + [104, 175]) ? 'retry' : 'finish' }

    queue = {
        task.memory < 128.GB   ? 'normalbw' :
        task.memory <= 190.GB  ? 'normal'   :
        task.memory <= 1020.GB ? 'hugemembw' : ''
    }

   withName: 'RUN_ALPHAFOLD2_PRED|RUN_ALPHAFOLD2|COLABFOLD_BATCH' {
      queue       = { params.use_gpu ? 'gpuhopper' : 'normal' }
      cpus        = { params.use_gpu ? 12 : 48 }
      accelerator = { params.use_gpu ? 1 : null }
      time        = { params.use_gpu ? 6.h : 24.h }
      memory      = { params.use_gpu ? 256.GB : 192.GB }
      disk        = { params.use_gpu ? null : 100.GB }
   }

   withName: 'RUN_BOLTZ' {
      queue       = 'gpuhopper'
      cpus        = 12
      accelerator = 1
      time        = 6.h
      memory      = 256.GB
      // Extra jobfs for the boltz mols directory symlinked as input
      disk        = 100.GB
   }

   withName: 'RUN_ALPHAFOLD2_MSA' {
      queue   = 'normalbw'
      cpus    = 18
      time    = 10.h
      memory  = 72.GB
      disk    = 100.GB
   }

   withName: 'MMSEQS_COLABFOLDSEARCH' {
      queue   = 'normalbw'
      memory  = 256.GB
      cpus    = 28
      time    = 8.h
      scratch = false
   }

   withName: 'MMCIF2PDB|FASTA2JSON|FASTA2YAML|MULTIQC|GENERATE_REPORT|MULTIFASTA_TO_CSV' {
      queue  = 'normalbw'
      memory = 4.GB
      cpus   = 1
      time   = 20.m
   }
}

singularity {
    runOptions = ''
    cacheDir   = '/g/data/if89/singularity_cache/'
}

executor {
    queueSize         = 300
    pollInterval      = 5.m
    queueStatInterval = 5.m
    submitRateLimit   = '20 min'
}

tower {
    enabled = true
    endpoint = 'https://seqera.services.biocommons.org.au/api'
}
