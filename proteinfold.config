// SBP Gadi configuration for nf-core/proteinfold

// NCI Gadi nf-core configuration profile
plugins {
    id 'nf-gadi@1.2.0'
}

// SBP required parameters; these are populated at runtime by the BioCommons service layer
params {
    db      = '/g/data/if89/proteinfold_dbs/proteinfold_minidbs/'
    project = System.getenv("PROJECT")
}

process {
    executor     = 'pbspro'
    // NOTE: placeholder values below — JOB_ID, USER_NAME, TIMESTAMP, FULL_NAME, INSTITUTE, IP_ADDRESS
    // are populated at runtime by the BioCommons service layer
    clusterOptions = '-P yz52  -v JOB_ID=test-job,USER_NAME=user_name@biocommon.org.au,TIMESTAMP=20260525_062803,FULL_NAME=your_name,INSTITUTE=biocommon.org.au,IP_ADDRESS=12.0.0.1'
    storage      = 'gdata/ll61+gdata/if89+gdata/li87'
    module       = 'singularity'
    cache        = 'lenient'
    stageInMode  = 'symlink'
    beforeScript = 'module load singularity'
    scratch       = true
    disk          = '20.GB'

    // NOTE: base.config uses (175..177); this config only retries on 175
    errorStrategy = { task.exitStatus in ((130..145) + 104 + 175) ? 'retry' : 'finish' }

    queue = {
        task.memory < 128.GB   ? 'normalbw' :
        task.memory <= 190.GB  ? 'normal'   :
        task.memory <= 1020.GB ? 'hugemembw' : ''
    }

   if (params.use_gpu) {
      withName: 'RUN_ALPHAFOLD2_PRED|RUN_ALPHAFOLD2|COLABFOLD_BATCH' {
         queue  = 'gpuhopper'
         cpus   = 12
         gpus   = 1
         time   = '6h'
         memory = '256.GB'
      }

      withName: 'RUN_BOLTZ' {
         queue  = 'gpuhopper'
         cpus   = 12
         gpus   = 1
         time   = '6h'
         memory = '256.GB'
         // Extra jobfs for the boltz mols directory symlinked as input
         disk   = '100.GB'
      }

   } else {
      withName: 'RUN_ALPHAFOLD2_PRED|RUN_ALPHAFOLD2|COLABFOLD_BATCH' {
         queue  = 'normal'
         cpus   = 48
         time   = '24h'
         memory = '192.GB'
         disk   = '100.GB'
      }
   }

   withName: 'RUN_ALPHAFOLD2_MSA' {
      queue   = 'normalbw'
      cpus    = 18
      time    = '10h'
      memory  = '72.GB'
      disk    = '100.GB'
   }

   withName: 'MMSEQS_COLABFOLDSEARCH' {
      queue   = 'normalbw'
      memory  = '256.GB'
      cpus    = 28
      time    = '8h'
      scratch = false
   }

   withName: 'MMCIF2PDB|FASTA2JSON|FASTA2YAML|MULTIQC|GENERATE_REPORT|MULTIFASTA_TO_CSV' {
      queue  = 'normalbw'
      memory = '4.GB'
      cpus   = 1
      time   = '20m'
   }
}

singularity {
    runOptions = ''
    cacheDir   = '/g/data/if89/singularity_cache/'
}

executor {
    queueSize         = 300
    pollInterval      = '5 min'
    queueStatInterval = '5 min'
    submitRateLimit   = '20 min'
}

workDir = '/scratch/yz52/sbp_service/workdir'

tower {
    enabled = true
    endpoint = 'https://seqera.services.biocommons.org.au/api'
}
